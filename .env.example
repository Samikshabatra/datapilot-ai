# Copy to backend/.env and fill in. All vars are prefixed AAA_.

# Provider: "gemini" (default) or "anthropic"
AAA_LLM_PROVIDER=gemini
AAA_GEMINI_API_KEY=your-gemini-key-here
# AAA_ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides (defaults shown, Gemini models)
# AAA_MODEL_GENERATE=gemini-2.5-flash
# AAA_MODEL_CORRECT=gemini-2.5-flash-lite
# AAA_MAX_RETRIES=3
# AAA_EXECUTION_TIMEOUT_S=30
# AAA_EXECUTOR_BACKEND=subprocess        # or "docker" for the isolated sandbox
# AAA_MAX_UPLOAD_MB=100

# Frontend -> backend URL (used by Streamlit). This project runs the backend on 8010.
# AAA_API_BASE=http://localhost:8010
